{
  "info": {
    "name": "Auth System",
    "description": "Complete API collection for the Auth System service.\n\nVariables:\n  - base_url      : service address (default http://localhost:8083)\n  - access_token  : auto-set by Login request\n  - refresh_token : auto-set by Login request",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8083" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
            "description": "Liveness + DB readiness probe."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('DB is up', () => pm.expect(pm.response.json().db).to.equal('up'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"test.user\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "description": "Register a new user. Returns the user profile (uuid, username, email, roles). The CITIZEN role is assigned automatically."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.expect(pm.response.code).to.equal(201));",
                  "pm.test('Response has uuid', () => pm.expect(pm.response.json().uuid).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/token (password)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"password\",\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/token", "host": ["{{base_url}}"], "path": ["auth", "token"] },
            "description": "OAuth2 password grant. Returns access_token, refresh_token, token_type, expires_in. Auto-stores access_token and refresh_token in collection variables."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Response has access_token', () => pm.expect(pm.response.json().access_token).to.be.a('string'));",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', body.access_token);",
                  "  pm.collectionVariables.set('refresh_token', body.refresh_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/token (refresh)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"refresh_token\",\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/token", "host": ["{{base_url}}"], "path": ["auth", "token"] },
            "description": "OAuth2 refresh token grant. Rotates the token pair."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', body.access_token);",
                  "  pm.collectionVariables.set('refresh_token', body.refresh_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/userinfo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/auth/userinfo", "host": ["{{base_url}}"], "path": ["auth", "userinfo"] },
            "description": "Get the current user's profile from the access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Response has uuid', () => pm.expect(pm.response.json().uuid).to.be.a('string'));",
                  "pm.test('Response has roles', () => pm.expect(pm.response.json().roles).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/revoke",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/revoke", "host": ["{{base_url}}"], "path": ["auth", "revoke"] },
            "description": "Revoke a refresh token. Requires a valid Bearer access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Response has message', () => pm.expect(pm.response.json().message).to.equal('Token revoked'));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/users (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/auth/users", "host": ["{{base_url}}"], "path": ["auth", "users"] },
            "description": "List all users. Requires ADMIN role. Returns safe fields only (no password hashes)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Response is an array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH /auth/users/:uuid/roles (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roles\": [\"ADMIN\", \"CITIZEN\"]\n}"
            },
            "url": { "raw": "{{base_url}}/auth/users/a0000000-0000-0000-0000-000000000001/roles", "host": ["{{base_url}}"], "path": ["auth", "users", "a0000000-0000-0000-0000-000000000001", "roles"] },
            "description": "Replace the roles of a user. The `roles` array completely replaces the existing roles. Requires ADMIN role."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('Response has roles array', () => pm.expect(pm.response.json().roles).to.be.an('array'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
